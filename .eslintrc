{
  "env": {
    "browser": true,
    "node": true,
    "jquery": true,
    "es2024": true
  },
  "extends": [
    "eslint:recommended",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": "warn",
    "no-unused-vars": "warn",
    "prefer-const": "error",
    "eqeqeq": ["error", "always"]
  }
}